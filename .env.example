# Thai Visa Assistant - Environment Variables

# Get from @BotFather on Telegram (IMPORTANT: keep this SECRET, never commit it)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Get from https://openrouter.ai/ (free credits available)
# This enables AI-powered answers
OPENROUTER_API_KEY=your_openrouter_api_key_here

# REQUIRED for production (Render/Railway): full URL where your bot is hosted
# Example: https://your-app.onrender.com
WEBHOOK_URL=your_render_app_url_here
